{
  "manifest_version": 3,
  "name": "ConsentLens",
  "version": "1.0",
  "description": "Scans and summarizes privacy policies in plain language.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.jpg",
      "48": "images/icon48.jpg"
    }
  },
  "icons": {
    "16": "images/icon16.jpg",
    "48": "images/icon48.jpg",
    "128": "images/icon128.jpg"
  }
}